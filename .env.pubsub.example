# ======================================
# Google Cloud Pub/Sub Configuration
# ======================================

# Habilitar/desabilitar consumo do Pub/Sub
# Defina como "true" para habilitar o consumo de mensagens
PUBSUB_ENABLED=false

# ID do projeto GCP (OBRIGATÓRIO se PUBSUB_ENABLED=true)
# Exemplo: meu-projeto-123456
GCP_PROJECT_ID=

# Nome da subscription do Pub/Sub (OBRIGATÓRIO se PUBSUB_ENABLED=true)
# Exemplo: bling-orders-subscription
GCP_PUBSUB_SUBSCRIPTION=

# Caminho para o arquivo de credenciais JSON (OPCIONAL)
# Se não fornecido, usa Application Default Credentials
# Exemplo: /app/credentials/gcp-service-account.json
GCP_KEY_FILENAME=

# ======================================
# Pub/Sub Performance Settings (OPCIONAL)
# ======================================

# Número máximo de mensagens processadas simultaneamente
# Padrão: 10 | Mínimo: 1 | Máximo: 1000
PUBSUB_MAX_MESSAGES=10

# Tempo em segundos para ACK (acknowledge) de mensagens
# Padrão: 60 | Mínimo: 10 | Máximo: 600
PUBSUB_ACK_DEADLINE=60

# Número máximo de tentativas de reprocessamento em caso de erro
# Padrão: 3 | Mínimo: 1 | Máximo: 10
PUBSUB_MAX_RETRIES=3
