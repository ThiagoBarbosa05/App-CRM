# ========================================
# Configurações de Automação (Opcional)
# ========================================

# Chave secreta para proteger endpoints de automação
# Descomente para ativar autenticação nos endpoints
# AUTOMATION_SECRET_KEY=sua-chave-super-secreta-aqui

# Ambiente de execução (development, production)
NODE_ENV=production

# ========================================
# Configurações Umbler (Obrigatório)
# ========================================

# ID da organização no Umbler
UMBLER_ORGANIZATION_ID=sua-org-id

# Token de autenticação Umbler
UMBLER_API_TOKEN=seu-token-aqui

# ========================================
# Banco de Dados
# ========================================

DATABASE_URL=sua-connection-string-aqui

# ========================================
# Cloudflare R2 / AWS S3 (Para arquivos)
# ========================================

CLOUDFLARE_URL=sua-url-cloudflare-r2
AWS_ACCESS_KEY_ID=seu-access-key
AWS_SECRET_ACCESS_KEY=seu-secret-key
CLOUDFLARE_BUCKET_NAME=seu-bucket-name
# Domínio público (CDN) que serve o bucket R2 — usado para gerar links de mídia
# acessíveis externamente (ex.: header de imagem de templates do WhatsApp).
R2_PUBLIC_URL=https://eventos.grandcrub2b.com
